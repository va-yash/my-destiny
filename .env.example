# Copy this file to .env and fill in your values.
# .env is in .gitignore — it will NEVER be committed.

# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get from https://opencagedata.com/ (free tier: 2500 req/day)
OPENCAGE_API_KEY=your-opencage-key-here

# Set this to your Vercel frontend URL after deployment.
# For local development you can leave it as * or http://localhost:5173
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional overrides (defaults shown)
CLAUDE_MODEL=claude-sonnet-4-5
MAX_TOKENS=2000
